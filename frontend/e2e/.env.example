# Copy to frontend/e2e/.env to run against staging with a specific account.
# Every value is OPTIONAL — when absent, the suite falls back to the in-repo
# staging-seed account and the baked-in staging URLs (see fixtures.ts). The
# .env file is gitignored; never commit a real password.

# Staging test account. Overrides the in-repo staging-seed fallback
# (hello@houzscentury.com, seeded by backend/scripts/staging-seed-account.mjs).
# In CI these come from the repo secrets STAGING_E2E_EMAIL / STAGING_E2E_PASSWORD.
STAGING_E2E_EMAIL=
STAGING_E2E_PASSWORD=

# Targets. Override only to point the suite at a preview or other environment.
# STAGING_BASE_URL=https://houzs-erp-staging.pages.dev
# STAGING_API_URL=https://autocount-sync-api-staging.houzs-erp.workers.dev
