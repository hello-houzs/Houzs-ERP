{
  "name": "autocount-sync-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:sw": "node scripts/check-service-worker.mjs",
    "check:test-focus": "node scripts/check-test-focus.mjs",
    "test:smoke-script": "node --test scripts/smoke-check.test.mjs",
    "smoke": "node scripts/smoke-check.mjs",
    "deploy": "npm run build && wrangler pages deploy --commit-dirty=true"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@types/leaflet": "^1.9.21",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.20",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
