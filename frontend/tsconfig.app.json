{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "zod": ["./node_modules/zod"],
      "@2990s/design-system": ["./src/vendor/design-system/index.ts"],
      "@2990s/shared/phone": ["./src/vendor/shared/phone.ts"],
      "@2990s/shared/mfg-pricing": ["./src/vendor/shared/mfg-pricing.ts"],
      "@2990s/shared/payment-methods": ["./src/vendor/scm/lib/payment-methods.ts"],
      "@2990s/shared/so-variant-rule": ["./src/vendor/shared/so-variant-rule.ts"],
      "@2990s/shared/so-line-display": ["./src/vendor/shared/so-line-display.ts"],
      "@2990s/shared": ["./src/vendor/shared/index.ts"],
      "@tanstack/react-virtual": ["./src/vendor/scm/lib/react-virtual-shim.ts"]
    }
  },
  "include": ["src"]
}
