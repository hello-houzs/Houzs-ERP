{
  "name": "houzs-erp-backend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "predeploy": "npm run typecheck && npm test",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:reset": "wrangler d1 execute autocount-sync --file=./src/db/schema.sql --remote",
    "db:reset:local": "wrangler d1 execute autocount-sync --local --file=./src/db/schema.sql",
    "db:migrate": "node scripts/migrate.mjs",
    "db:migrate:baseline": "node scripts/migrate.mjs --baseline"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "postgres": "^3.4.9",
    "qrcode-generator": "^2.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20241218.0",
    "better-sqlite3": "^12.10.0",
    "sql.js": "^1.14.1",
    "typescript": "^5.7.0",
    "vitest": "~3.0.0",
    "wrangler": "^4.81.0"
  }
}
