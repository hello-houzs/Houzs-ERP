{
  "name": "houzs-erp-backend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "predeploy": "npm run typecheck && npm test",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit -p .",
    "pretest": "npm run test:scale-contract",
    "test": "vitest run",
    "test:pg": "vitest run --config vitest.pg.config.ts",
    "test:watch": "vitest",
    "test:scale-contract": "node --test tests/scaleTargetGuard.node.mjs tests/scaleRealSchemaContract.node.mjs tests/scaleRouteDrift.node.mjs tests/routeMatrixDrift.node.mjs",
    "perf:scale": "node scripts/scale-harness.mjs",
    "audit:routes": "node scripts/generate-route-capability-matrix.mjs --check",
    "audit:map": "node scripts/gen-codebase-map.mjs --check",
    "db:reset": "wrangler d1 execute autocount-sync --file=./src/db/schema.sql --remote",
    "db:reset:local": "wrangler d1 execute autocount-sync --local --file=./src/db/schema.sql",
    "db:migrate": "node scripts/migrate.mjs",
    "db:migrate:baseline": "node scripts/migrate.mjs --baseline"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31",
    "postgres": "^3.4.9",
    "qrcode-generator": "^2.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260719.1",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "sql.js": "^1.14.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
