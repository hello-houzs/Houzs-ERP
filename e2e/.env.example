# Copy to .env and fill in real values. .env is git-ignored.

# Where your staff UI lives (local dev, staging, or prod)
ERP_BASE_URL=http://localhost:5173

# Worker API URL (used for direct REST calls — login, polling, etc.)
ERP_API_URL=https://autocount-sync-api.houzs-erp.workers.dev

# Staff login for the admin-side flows. Must have
# service_cases.manage + service_cases.read.
STAFF_EMAIL=dispatcher@houzscentury.com
STAFF_PASSWORD=your-password-here

# A REAL sales order in AutoCount that has a phone number on it.
# The test uses this to exercise the SO lookup + case creation flow.
TEST_SO_NO=SO/2604-001
TEST_SO_PHONE=012-345 6789

# Optional: a supplier to use. If blank, the test creates a throwaway
# "[E2E] Test Upholstery" supplier on first run.
TEST_SUPPLIER_NAME=
